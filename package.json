{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "pharmasys",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev-local.ts",
    "dev:remote": "bun scripts/dev-remote.ts",
    "dev:strict": "bun scripts/dev-strict.ts",
    "dev:strict:remote": "bun scripts/dev-strict.ts --remote",
    "dev:vite": "bun scripts/dev-local.ts",
    "build": "vp build",
    "lint": "vp lint . --deny-warnings",
    "lint:fix": "vp lint . --fix --deny-warnings",
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "check": "vp check",
    "typecheck": "vp exec tsc -b --noEmit",
    "typecheck:watch": "vp exec tsc -b --noEmit --watch --preserveWatchOutput",
    "check:chat-schema": "bun scripts/check-chat-schema-types.ts",
    "check:chat-schema:fix": "bun scripts/check-chat-schema-types.ts --fix",
    "check:chat-schema:live": "bun scripts/check-chat-schema-types.ts --require-live",
    "check:generated": "bun scripts/check-generated-artifacts.ts",
    "check:generated:fix": "bun scripts/check-generated-artifacts.ts --fix",
    "check:db-types": "bun scripts/check-generated-artifacts.ts --only=db-types",
    "check:db-types:fix": "bun scripts/check-generated-artifacts.ts --fix --only=db-types",
    "preview": "vp preview",
    "preview:remote": "bun scripts/preview-remote.ts",
    "test": "vp test watch",
    "test:ui": "vp test --ui",
    "test:coverage": "vp test run --coverage",
    "test:coverage:strict": "vp test run --coverage && bun scripts/check-coverage-100.ts",
    "coverage:check": "bun scripts/check-coverage-100.ts",
    "test:agent": "AI_AGENT=codex vp test run --passWithNoTests",
    "test:agent:watch": "AI_AGENT=codex vp test watch",
    "test:agent:run": "AI_AGENT=codex vp test run --passWithNoTests",
    "test:e2e": "PLAYWRIGHT_HTML_OPEN=never playwright test",
    "test:run:agent": "AI_AGENT=codex vp test run --passWithNoTests",
    "coverage:non-runtime:refresh": "bun scripts/coverage/generate-non-runtime-files.ts",
    "test:coverage:open": "vp test run --coverage && open coverage/index.html",
    "test:run": "vp test run --passWithNoTests",
    "test:watch": "vp test watch",
    "test:changed": "vp test --changed",
    "test:related": "vp test related",
    "add-admin": "bun scripts/add-admin-user.ts",
    "add-admin:help": "bun scripts/add-admin-user.ts --help",
    "update-password": "bun scripts/update-user-password.ts",
    "update-password:help": "bun scripts/update-user-password.ts --help",
    "backfill:chat-image-previews": "bun scripts/backfill-chat-image-previews.ts",
    "backfill:profile-photo-thumbnails": "bun scripts/backfill-profile-photo-thumbnails.ts",
    "export": "bun scripts/export.ts",
    "loc-stats": "bun scripts/loc-stats.ts",
    "codex:seed": "bun scripts/seed-codex.ts",
    "codex:seed:interactive": "bun scripts/seed-codex.ts --interactive",
    "gen:chat-schema": "bun run check:chat-schema:fix",
    "gen:db-types": "bun run check:db-types:fix",
    "gen:schemas": "bun scripts/check-generated-artifacts.ts --fix --only=zod",
    "gen:schemas:db": "bun scripts/check-generated-artifacts.ts --fix --only=zod --zod=database",
    "gen:schemas:forms": "bun scripts/check-generated-artifacts.ts --fix --only=zod --zod=forms",
    "gen:schemas:invoice": "bun scripts/check-generated-artifacts.ts --fix --only=zod --zod=invoice",
    "gen:schemas:purchase": "bun scripts/check-generated-artifacts.ts --fix --only=zod --zod=purchase",
    "prepare": "husky && bun run codex:seed"
  },
  "dependencies": {
    "@ag-grid-community/locale": "35.3.1",
    "@floating-ui/react-dom": "^2.1.8",
    "@headlessui/react": "^2.2.10",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.4",
    "ag-grid-community": "35.3.1",
    "ag-grid-enterprise": "35.3.1",
    "ag-grid-react": "35.3.1",
    "axios": "^1.18.1",
    "browser-image-compression": "^2.0.2",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "compressorjs": "^1.3.0",
    "fuzzysort": "^3.1.0",
    "motion": "^12.40.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.17.0",
    "react-spinners": "^0.17.0",
    "recharts": "3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "convert-to-oklch": "file:dev-tools/convert-to-oklch",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.100.0",
    "shadcn": "^4.11.0",
    "supabase": "2.105.0",
    "tailwindcss": "4.3.0",
    "ts-to-zod": "^5.1.0",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.3.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vite-plus": "0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
  },
  "overrides": {
    "glob": "^11.1.0",
    "js-yaml": "^4.1.1",
    "jws": "^4.0.1",
    "qs": "^6.14.1",
    "tar": "^7.5.3"
  },
  "packageManager": "bun@1.3.13"
}
